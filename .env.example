# Absolute path to the Stockfish executable.
# Windows example: C:\Tools\Stockfish\stockfish-windows-x86-64-avx2.exe
# macOS/Linux example: /usr/local/bin/stockfish
STOCKFISH_PATH=

# Optional Gemini configuration. If incomplete or unavailable, the application
# automatically uses deterministic template explanations.
AI_PROVIDER=gemini
AI_API_KEY=
AI_MODEL=gemini-3.1-flash-lite

# PostgreSQL persistence. Leave DATABASE_URL empty to disable history storage.
DATABASE_URL=postgresql+psycopg://chess_coach:chess_coach@localhost:5432/chess_coach
COACH_USERNAME=local-player
